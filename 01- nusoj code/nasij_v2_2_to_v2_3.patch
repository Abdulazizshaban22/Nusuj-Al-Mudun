 def register(app):
     app.include_router(router)
+
+
+@router.get("/gi_hotspots_geojson")
+def gi_hotspots_geojson(metric: str = "fabric_index"):
+    """Return GeoJSON with Gi* z-scores and class (hot/cold/not_sig)."""
+    import json as _json, numpy as _np, math as _math
+    with _db() as conn:
+        rows = conn.execute("""
+            SELECT uc.id, ST_AsGeoJSON(uc.geom) AS gj,
+                   fi.efficiency, fi.resilience, fi.connectivity
+            FROM urban_cells uc
+            LEFT JOIN fabric_indicators fi ON fi.cell_id = uc.id
+            ORDER BY uc.id
+        """).fetchall()
+        nbors = conn.execute("""
+            SELECT a.id AS src, b.id AS dst
+            FROM urban_cells a
+            JOIN urban_cells b ON a.id < b.id AND ST_Touches(a.geom, b.geom)
+        """).fetchall()
+
+    ids, geoms, vals = [], [], []
+    for (cid, gj, eff, res, con) in rows:
+        eff, res, con = float(eff or 0.6), float(res or 0.6), float(con or 0.6)
+        if metric in ("fabric_index","fabric"):
+            v = 0.4*eff + 0.3*res + 0.3*con
+        elif metric == "connectivity":
+            v = con
+        elif metric == "efficiency":
+            v = eff
+        elif metric == "resilience":
+            v = res
+        else:
+            v = (eff+res+con)/3.0
+        ids.append(int(cid)); geoms.append(gj); vals.append(float(v))
+
+    idx = {cid:i for i,cid in enumerate(ids)}
+    neighbors = [[] for _ in ids]
+    for (s,d) in nbors:
+        i, j = idx[int(s)], idx[int(d)]
+        neighbors[i].append(j); neighbors[j].append(i)
+
+    x = _np.array(vals, dtype=float); mean = float(_np.mean(x)); sd = float(_np.std(x)+1e-12)
+    zscores = []
+    for i, nbrs in enumerate(neighbors):
+        wi = len(nbrs)+1
+        s = x[i] + _np.sum(x[nbrs]) if nbrs else x[i]
+        z = (s - mean*wi) / (sd * (wi**0.5))
+        zscores.append(float(z))
+
+    feats=[]
+    for (cid, gj, z) in zip(ids, geoms, zscores):
+        cls = "hot" if z>=1.96 else ("cold" if z<=-1.96 else "not_sig")
+        feats.append({
+          "type":"Feature",
+          "properties":{"id":cid,"z":z,"class":cls},
+          "geometry": _json.loads(gj) if gj else None
+        })
+    return {"type":"FeatureCollection","features":feats}
+
+
+@router.get("/h3_aggregate")
+def h3_aggregate(res: int = 8, metric: str = "fabric_index"):
+    """Aggregate cell metric to H3 hexagons (average)."""
+    import json as _json
+    with _db() as conn:
+        rows = conn.execute("""
+            SELECT uc.id, ST_Y(ST_Centroid(uc.geom)) AS lat,
+                   ST_X(ST_Centroid(uc.geom)) AS lon,
+                   fi.efficiency, fi.resilience, fi.connectivity
+            FROM urban_cells uc
+            LEFT JOIN fabric_indicators fi ON fi.cell_id = uc.id
+        """).fetchall()
+
+    data=[]
+    for (cid, lat, lon, eff, resi, con) in rows:
+        eff, resi, con = float(eff or 0.6), float(resi or 0.6), float(con or 0.6)
+        if metric in ("fabric_index","fabric"): v = 0.4*eff + 0.3*resi + 0.3*con
+        elif metric=="connectivity": v = con
+        elif metric=="efficiency": v = eff
+        elif metric=="resilience": v = resi
+        else: v = (eff+resi+con)/3.0
+        data.append((float(lat), float(lon), float(v)))
+
+    agg = {}
+    for (lat, lon, v) in data:
+        h = h3.geo_to_h3(lat, lon, int(res))
+        s = agg.get(h, {"sum":0.0,"n":0}); s["sum"] += v; s["n"] += 1; agg[h]=s
+
+    feats=[]
+    for h, s in agg.items():
+        avg = s["sum"]/max(1,s["n"])
+        boundary = h3.h3_to_geo_boundary(h, geo_json=True)
+        geom = {"type":"Polygon", "coordinates":[boundary+[boundary[0]]]}  # close ring
+        feats.append({"type":"Feature","properties":{"h3":h,"value":avg,"n":s["n"]},"geometry":geom})
+    return {"type":"FeatureCollection","features":feats}
